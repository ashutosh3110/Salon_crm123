# Copy to .env — never commit real .env
NODE_ENV=development
PORT=3000
MONGODB_URI=mongodb://127.0.0.1:27017/salon_crm
JWT_SECRET=change-me

# Browser origin(s) that may call the API (comma-separated).
# Login uses credentials — origin must match exactly (localhost vs 127.0.0.1 are different).
# Dev: backend also allows any http(s)://localhost|127.0.0.1:PORT when NODE_ENV is not production.
# Phone/LAN testing: add your machine IP, e.g. http://192.168.1.5:5173
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
